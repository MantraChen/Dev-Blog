---
import { ThemeToggle } from "@/components/ThemeToggle"
---

<header class="sticky top-0 z-50 w-full border-b bg-background/95 backdrop-blur supports-[backdrop-filter]:bg-background/60">
  <div class="container mx-auto flex h-14 max-w-5xl items-center justify-between px-4">
    <nav class="flex items-center space-x-6 text-sm font-medium">
      <a href="/" class="transition-colors hover:text-foreground/80 text-foreground">Home</a>
      <a href="/blog" class="transition-colors hover:text-foreground/80 text-foreground/60">Blog</a>
      <a href="/projects" class="transition-colors hover:text-foreground/80 text-foreground/60">Projects</a>
      <a href="/skills" class="transition-colors hover:text-foreground/80 text-foreground/60">Skills</a>
      <a href="/timeline" class="transition-colors hover:text-foreground/80 text-foreground/60">Timeline</a>
      <a href="/archive" class="transition-colors hover:text-foreground/80 text-foreground/60">Archive</a>
      <a href="/friends" class="transition-colors hover:text-foreground/80 text-foreground/60">Friends</a>
    </nav>
    <div class="flex items-center space-x-4">
      <ThemeToggle client:load />
    </div>
  </div>
</header>
