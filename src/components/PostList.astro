---
import type { PostListItem } from '../db/types';

interface Props {
  posts: PostListItem[];
}

const { posts } = Astro.props;
---

<div class="space-y-6">
  {posts.map((post) => (
    <article class="group relative flex flex-col items-start justify-between">
      <div class="flex items-center gap-x-4 text-xs mb-2">
        <time datetime={post.publishedAt} class="text-zinc-500">
          {new Date(post.publishedAt).toLocaleDateString()}
        </time>
        <div class="flex gap-2">
          {post.tags.map(tag => (
            <span class="relative z-10 rounded-full bg-zinc-900 px-3 py-1.5 font-medium text-zinc-400">
              {tag}
            </span>
          ))}
        </div>
      </div>
      <div class="group relative">
        <h3 class="text-lg font-semibold leading-6 text-zinc-100 group-hover:text-zinc-300">
          <a href={`/posts/${post.slug}`}>
            <span class="absolute inset-0"></span>
            {post.title}
          </a>
        </h3>
      </div>
    </article>
  ))}
</div>