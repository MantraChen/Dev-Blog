---
import BaseLayout from "@/components/layout/BaseLayout.astro"
---

<BaseLayout title="404 | Not Found">
  <div class="flex flex-col items-center justify-center min-h-[60vh] text-center">
    <h1 class="text-7xl font-extrabold tracking-tighter text-muted-foreground/30 mb-4">404</h1>
    <p class="text-xl font-medium mb-2">Page not found</p>
    <p class="text-muted-foreground mb-8">The page you're looking for doesn't exist or has been moved.</p>
    <a
      href="/"
      class="inline-flex items-center justify-center rounded-md text-sm font-medium h-10 px-6 bg-primary text-primary-foreground hover:bg-primary/90 transition-colors"
    >
      Back to Home
    </a>
  </div>
</BaseLayout>
