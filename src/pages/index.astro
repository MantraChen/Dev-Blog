---
import BaseLayout from "@/components/layout/BaseLayout.astro"
import { getLatestStatuses, getProjectList, getSkillList, getPublishedPosts } from "@/db/queries"
import { estimateReadingTime } from "@/lib/utils"

const statuses = await getLatestStatuses(1)
const projects = await getProjectList()
const skills = await getSkillList()
const allPosts = await getPublishedPosts()
const recentPosts = allPosts.slice(0, 3)

const topProjects = projects.slice(0, 3)
const topSkills = skills.slice(0, 12)
---

<BaseLayout title="Mantra Chen | Tech Blog">
  <section class="space-y-8 pb-8 pt-6 md:pb-12 md:pt-10 lg:py-24">
    <div class="flex max-w-[64rem] flex-col items-start gap-6">

      <div class="hero-animate" style="animation-delay: 0ms">
        <h1 class="font-heading text-4xl sm:text-5xl md:text-6xl font-bold tracking-tight mb-4">
          Hi, I'm Mantra Chen.
        </h1>
        <p class="max-w-[42rem] leading-normal text-muted-foreground sm:text-xl sm:leading-8">
          CTO & Systems Developer.
          Writing C++, Java, Python, and Rust to build systems that are fast and unbreakable.
          Specializing in extreme-performance algorithms and kernel-space security.
        </p>
      </div>

      <div class="max-w-[42rem] p-5 border rounded-lg bg-zinc-50 dark:bg-zinc-900/50 relative overflow-hidden group hero-animate" style="animation-delay: 150ms">
        <div class="absolute w-1 h-full bg-zinc-300 dark:bg-zinc-700 left-0 top-0 transition-colors group-hover:bg-foreground"></div>
        <h2 class="text-sm font-semibold uppercase tracking-wider text-foreground mb-2">Why this blog?</h2>
        <p class="text-sm text-muted-foreground leading-relaxed">
          Honestly, I built this just because I was bored and had too much free time.
          Now it serves as a public dump for my thoughts on lock-free algorithms, memory arenas, and whatever backend architecture I'm currently obsessing over.
        </p>
      </div>

      <div class="flex items-center gap-4 hero-animate" style="animation-delay: 300ms">
        <a
          href="https://github.com/mantrachen"
          target="_blank"
          rel="noreferrer"
          class="inline-flex items-center justify-center rounded-md text-sm font-medium transition-colors focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring bg-primary text-primary-foreground shadow hover:bg-primary/90 h-9 px-4 py-2"
        >
          <svg class="mr-2 h-4 w-4" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          GitHub Profile
        </a>

        {statuses.length > 0 && (
          <div class="flex items-center gap-2 text-sm text-muted-foreground px-3 py-1.5 rounded-full border bg-background">
            <span class="relative flex h-2 w-2">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-green-500"></span>
            </span>
            <span class="font-medium text-foreground/80">{statuses[0].text}</span>
          </div>
        )}
      </div>

    </div>
  </section>

  <div class="grid gap-12 md:grid-cols-2 mt-8">
    <section>
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-2xl font-semibold tracking-tight">Recent Writing</h2>
        <a href="/blog" class="text-sm font-medium hover:underline flex items-center text-muted-foreground hover:text-foreground transition-colors">
          View all <svg class="ml-1 h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
      <div class="flex flex-col gap-4">
        {recentPosts.map((post) => (
          <a href={`/blog/${post.slug}`} class="group flex flex-col rounded-lg border bg-card transition-all duration-300 ease-out hover:-translate-y-1 hover:shadow-sm dark:hover:shadow-zinc-800/50 hover:border-zinc-300 dark:hover:border-zinc-700 overflow-hidden">
            {post.coverImage && (
              <img
                src={post.coverImage}
                alt={post.title}
                class="w-full h-32 aspect-video object-cover border-b border-border bg-muted/50"
              />
            )}
            <div class="p-5 flex flex-col gap-2">
              <h3 class="font-semibold group-hover:text-primary transition-colors">{post.title}</h3>
              <p class="text-sm text-muted-foreground line-clamp-2">{post.description}</p>
              <div class="flex items-center gap-2 text-xs text-muted-foreground mt-2">
                <time>
                  {new Date(post.publishedAt).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
                </time>
                <span>·</span>
                <span>{estimateReadingTime(post.content)} min read</span>
              </div>
            </div>
          </a>
        ))}
        {recentPosts.length === 0 && (
          <p class="text-sm text-muted-foreground italic">No posts yet. Still slacking off.</p>
        )}
      </div>
    </section>

    <div class="space-y-12">
      <section>
        <div class="flex items-center justify-between mb-6">
          <h2 class="text-2xl font-semibold tracking-tight">Featured Projects</h2>
          <a href="/projects" class="text-sm font-medium hover:underline flex items-center text-muted-foreground hover:text-foreground transition-colors">
            View all <svg class="ml-1 h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>
        <div class="grid gap-4">
          {topProjects.map((project) => (
            <div class="group rounded-lg border bg-card text-card-foreground border-transparent hover:border-primary/20 transition-all duration-300 ease-out hover:-translate-y-1 hover:scale-[1.02] hover:shadow-lg hover:shadow-primary/5 dark:hover:shadow-primary/10">
              <div class="p-5 pb-3">
                <div class="text-lg font-semibold flex items-center justify-between">
                  {project.name}
                  {project.repoUrl && (
                    <a href={project.repoUrl} target="_blank" rel="noreferrer" class="text-muted-foreground hover:text-foreground transition-colors">
                      <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
                    </a>
                  )}
                </div>
                <p class="text-sm text-muted-foreground leading-relaxed mt-1.5">{project.description}</p>
              </div>
              <div class="p-5 pt-0 flex gap-2 flex-wrap">
                {project.techStack.map((tech: string) => (
                  <span class="inline-flex items-center rounded-full border px-2.5 py-0.5 text-xs font-normal bg-secondary/50 text-secondary-foreground group-hover:bg-primary/10 group-hover:text-primary transition-colors">{tech}</span>
                ))}
              </div>
            </div>
          ))}
        </div>
      </section>

      <section>
        <h2 class="text-2xl font-semibold tracking-tight mb-6">Core Stack</h2>
        <div class="flex flex-wrap gap-2">
          {topSkills.map((skill) => (
            <span class="inline-flex items-center rounded-full border px-2.5 py-0.5 text-xs font-normal text-foreground">{skill.name}</span>
          ))}
        </div>
      </section>
    </div>
  </div>
</BaseLayout>
