---
import { getCollection, render } from "astro:content"
import BaseLayout from "@/components/layout/BaseLayout.astro"

const { slug } = Astro.params

const allPosts = await getCollection("blog", ({ data }) => !data.draft)
const entry = allPosts.find((p) => p.id === slug)

if (!entry) {
  return Astro.redirect("/blog")
}

const { Content, headings, remarkPluginFrontmatter } = await render(entry)
const tocHeadings = headings.filter((h) => h.depth <= 3)

// Auto-generate description from body if not explicitly provided
const description = entry.data.description || (entry.body ? entry.body.replace(/[#*`>\-\[\]()!{}\n]/g, ' ').replace(/\s+/g, ' ').trim().slice(0, 150) + '…' : entry.data.title)

Astro.response.headers.set('Cache-Control', 'public, max-age=600, stale-while-revalidate=3600')
---

<BaseLayout title={`${entry.data.title} | Blog`} description={description}>
  <!-- Reading Progress Bar -->
  <div id="reading-progress"></div>

  <div class="max-w-4xl mx-auto py-10 flex gap-10">
    <!-- Article -->
    <article class="flex-1 min-w-0">
      <header class="mb-10 reveal">
        <h1 class="text-4xl font-extrabold tracking-tight lg:text-5xl mb-4">{entry.data.title}</h1>
        <time class="text-muted-foreground">
          {entry.data.publishedAt.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}
        </time>
        <div class="flex flex-wrap gap-2 mt-4">
          {entry.data.tags.map((tag) => (
            <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold bg-secondary text-secondary-foreground">{tag}</span>
          ))}
        </div>
      </header>
      <div class="prose prose-zinc dark:prose-invert max-w-none prose-pre:bg-zinc-950 prose-pre:border prose-pre:rounded-lg prose-lead:leading-relaxed reveal">
        <Content />
      </div>
    </article>

    <!-- Table of Contents (desktop sidebar) -->
    {tocHeadings.length > 0 && (
      <aside class="hidden lg:block w-56 shrink-0">
        <nav class="sticky top-20">
          <p class="text-sm font-semibold mb-3 text-muted-foreground">On this page</p>
          <ul class="space-y-2 text-sm">
            {tocHeadings.map((h) => (
              <li style={`padding-left: ${(h.depth - 2) * 0.75}rem`}>
                <a
                  href={`#${h.slug}`}
                  class="toc-link text-muted-foreground hover:text-foreground transition-colors block py-0.5"
                  data-slug={h.slug}
                >
                  {h.text}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </aside>
    )}
  </div>

  <!-- Reading progress + code copy + TOC highlight -->
  <script is:inline>
    function initBlogEnhancements() {
      // Reading progress bar
      const bar = document.getElementById('reading-progress');
      if (bar) {
        const updateProgress = () => {
          const scrollTop = window.scrollY;
          const docHeight = document.documentElement.scrollHeight - window.innerHeight;
          bar.style.width = docHeight > 0 ? (scrollTop / docHeight * 100) + '%' : '0%';
        };
        window.addEventListener('scroll', updateProgress, { passive: true });
        updateProgress();
      }

      // Code copy buttons
      document.querySelectorAll('.prose pre').forEach(pre => {
        if (pre.querySelector('.copy-btn')) return;
        const btn = document.createElement('button');
        btn.className = 'copy-btn';
        btn.textContent = 'Copy';
        btn.addEventListener('click', async () => {
          const code = pre.querySelector('code')?.textContent || '';
          await navigator.clipboard.writeText(code);
          btn.textContent = 'Copied!';
          setTimeout(() => btn.textContent = 'Copy', 1500);
        });
        pre.appendChild(btn);
      });

      // TOC active heading highlight
      const tocLinks = document.querySelectorAll('.toc-link');
      if (tocLinks.length > 0) {
        const headingEls = Array.from(tocLinks).map(l =>
          document.getElementById(l.dataset.slug)
        ).filter(Boolean);

        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              tocLinks.forEach(l => l.classList.remove('text-foreground', 'font-medium'));
              const active = document.querySelector(`.toc-link[data-slug="${entry.target.id}"]`);
              if (active) active.classList.add('text-foreground', 'font-medium');
            }
          });
        }, { rootMargin: '-80px 0px -60% 0px' });

        headingEls.forEach(el => observer.observe(el));
      }
    }
    initBlogEnhancements();
    document.addEventListener('astro:after-swap', initBlogEnhancements);
  </script>
</BaseLayout>
