---
import { getCollection, render } from "astro:content"
import BaseLayout from "@/components/layout/BaseLayout.astro"

const { slug } = Astro.params

const allPosts = await getCollection("blog")
const entry = allPosts.find((p) => p.id === slug)

if (!entry) {
  return Astro.redirect("/blog")
}

const { Content } = await render(entry)
---

<BaseLayout title={`${entry.data.title} | Blog`} description={entry.data.description}>
  <article class="max-w-3xl mx-auto py-10">
    <header class="mb-10 text-center flex flex-col items-center">
      <h1 class="text-4xl font-extrabold tracking-tight lg:text-5xl mb-4">{entry.data.title}</h1>
      <time class="text-muted-foreground mb-6">
        {entry.data.publishedAt.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}
      </time>
      <div class="flex flex-wrap gap-2 justify-center">
        {entry.data.tags.map((tag) => (
          <span class="inline-flex items-center rounded-full border px-2.5 py-0.5 text-xs font-semibold bg-secondary text-secondary-foreground">{tag}</span>
        ))}
      </div>
    </header>
    <div class="prose prose-zinc dark:prose-invert max-w-none prose-pre:bg-zinc-950 prose-pre:border">
      <Content />
    </div>
  </article>
</BaseLayout>
