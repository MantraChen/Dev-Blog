---
import BaseLayout from "@/components/layout/BaseLayout.astro"
import { getPostBySlug, getPostViewCount, recordPostView, getAdjacentPosts } from "@/db/queries"
import { marked } from "@/lib/markdown"
import { estimateReadingTime } from "@/lib/utils"
import { ReactionBar } from "@/components/blog/ReactionBar"

const { slug } = Astro.params

const post = await getPostBySlug(slug!)

if (!post || post.draft) {
  return Astro.redirect("/blog")
}

// 记录浏览量并获取计数和前后文章
await recordPostView(slug!)
const viewCount = await getPostViewCount(slug!)
const { prev, next } = await getAdjacentPosts(slug!)

// 计算阅读时间
const readingTime = estimateReadingTime(post.content)

// Render markdown to HTML
const htmlContent = await marked.parse(post.content)

// Extract headings for TOC
const headingRegex = /<h([1-3])\s+id="([^"]*)"[^>]*>(.*?)<\/h\1>/gi
const tocHeadings: { depth: number; slug: string; text: string }[] = []
let match
while ((match = headingRegex.exec(htmlContent)) !== null) {
  tocHeadings.push({
    depth: parseInt(match[1]),
    slug: match[2],
    text: match[3].replace(/<[^>]+>/g, ""),
  })
}

// Auto-generate description if not provided
const description = post.description || post.content.replace(/[#*`>\-\[\]()!{}\n]/g, ' ').replace(/\s+/g, ' ').trim().slice(0, 150) + '...'

const publishedDate = new Date(post.publishedAt)

Astro.response.headers.set('Cache-Control', 'public, max-age=600, stale-while-revalidate=3600')
---

<BaseLayout title={`${post.title} | Blog`} description={description}>
  <div id="reading-progress"></div>

  <div class="max-w-4xl mx-auto py-10 flex gap-10">
    <article class="flex-1 min-w-0">

      <header class="mb-10 reveal">
        {post.coverImage && (
          <div class="relative w-full aspect-video rounded-lg overflow-hidden mb-6 border border-border">
            <img
              src={post.coverImage}
              alt={post.title}
              class="absolute inset-0 w-full h-full object-cover"
            />
            <div class="absolute inset-0 bg-linear-to-t from-background via-background/60 to-transparent"></div>
            <div class="absolute bottom-0 left-0 right-0 p-6 md:p-8">
              <h1 class="text-3xl font-extrabold tracking-tight lg:text-4xl text-foreground drop-shadow-md">{post.title}</h1>
              <div class="flex items-center gap-4 text-muted-foreground mt-3">
                <time>
                  {publishedDate.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}
                </time>
                <span>·</span>
                <span>{readingTime} min read</span>
                <span>·</span>
                <span>{viewCount} 次阅读</span>
              </div>
              <div class="flex flex-wrap gap-2 mt-3">
                {post.tags.map((tag) => (
                  <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold bg-background/70 text-foreground backdrop-blur-sm">{tag}</span>
                ))}
              </div>
            </div>
          </div>
        )}
        {!post.coverImage && (
          <>
            <h1 class="text-4xl font-extrabold tracking-tight lg:text-5xl mb-4">{post.title}</h1>
            <div class="flex items-center gap-4 text-muted-foreground">
              <time>
                {publishedDate.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}
              </time>
              <span>·</span>
              <span>{readingTime} min read</span>
              <span>·</span>
              <span>{viewCount} 次阅读</span>
            </div>
            <div class="flex flex-wrap gap-2 mt-4">
              {post.tags.map((tag) => (
                <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold bg-secondary text-secondary-foreground">{tag}</span>
              ))}
            </div>
          </>
        )}
      </header>

      <div class="prose prose-zinc dark:prose-invert max-w-none prose-pre:bg-zinc-950 prose-pre:border prose-pre:rounded-lg prose-lead:leading-relaxed reveal">
        <Fragment set:html={htmlContent} />
      </div>

      <ReactionBar slug={slug!} client:idle />

      <nav class="mt-12 flex justify-between items-center border-t border-border pt-6">
        {prev ? (
          <a href={`/blog/${prev.slug}`} class="text-sm text-muted-foreground hover:text-foreground transition-colors">
            ← {prev.title}
          </a>
        ) : <span />}
        {next ? (
          <a href={`/blog/${next.slug}`} class="text-sm text-muted-foreground hover:text-foreground transition-colors text-right">
            {next.title} →
          </a>
        ) : <span />}
      </nav>

      <section class="mt-12">
        <script
          src="https://giscus.app/client.js"
          data-repo="MantraChen/Dev-Blog"
          data-repo-id="R_kgDORxxsSQ"
          data-category="Announcements"
          data-category-id="DIC_kwDORxxsSc4C5bq6"
          data-mapping="pathname"
          data-strict="1"
          data-reactions-enabled="1"
          data-emit-metadata="0"
          data-input-position="top"
          data-theme="preferred_color_scheme"
          data-lang="zh-CN"
          data-loading="lazy"
          crossorigin="anonymous"
          async
        ></script>
      </section>
    </article>

    {tocHeadings.length > 0 && (
      <aside class="hidden lg:block w-56 shrink-0">
        <nav class="sticky top-20">
          <p class="text-sm font-semibold mb-3 text-muted-foreground">On this page</p>
          <ul class="space-y-2 text-sm">
            {tocHeadings.map((h) => (
              <li style={`padding-left: ${(h.depth - 2) * 0.75}rem`}>
                <a
                  href={`#${h.slug}`}
                  class="toc-link text-muted-foreground hover:text-foreground transition-colors block py-0.5"
                  data-slug={h.slug}
                >
                  {h.text}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </aside>
    )}
  </div>

  {tocHeadings.length > 0 && (
    <>
      <button
        id="mobile-toc-btn"
        class="lg:hidden fixed bottom-20 right-6 z-40 h-10 w-10 rounded-full bg-primary text-primary-foreground shadow-lg flex items-center justify-center hover:bg-primary/90 transition-colors"
        aria-label="Table of Contents"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="8" x2="21" y1="6" y2="6"/>
          <line x1="8" x2="21" y1="12" y2="12"/>
          <line x1="8" x2="21" y1="18" y2="18"/>
          <line x1="3" x2="3.01" y1="6" y2="6"/>
          <line x1="3" x2="3.01" y1="12" y2="12"/>
          <line x1="3" x2="3.01" y1="18" y2="18"/>
        </svg>
      </button>

      <div id="toc-overlay" class="fixed inset-0 bg-black/50 backdrop-blur-sm z-40 hidden opacity-0 transition-opacity duration-300 lg:hidden"></div>

      <div id="toc-drawer" class="fixed bottom-0 left-0 right-0 z-50 bg-background border-t border-border rounded-t-xl max-h-[60vh] flex flex-col translate-y-full transition-transform duration-300 ease-out lg:hidden">
        <div class="flex items-center justify-between p-4 border-b border-border shrink-0">
          <span class="font-semibold text-foreground">On this page</span>
          <button id="toc-close-btn" class="text-muted-foreground hover:text-foreground p-1 rounded-md hover:bg-muted transition-colors" aria-label="Close">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
          </button>
        </div>
        <div class="overflow-y-auto p-4">
          <ul class="space-y-2 text-sm">
            {tocHeadings.map((h) => (
              <li class={h.depth === 3 ? "pl-4" : ""}>
                <a
                  href={`#${h.slug}`}
                  class="mobile-toc-link block py-2 text-muted-foreground hover:text-foreground transition-colors"
                  data-slug={h.slug}
                >
                  {h.text}
                </a>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </>
  )}

  <script is:inline>
    function initBlogEnhancements() {
      // Reading progress bar
      const bar = document.getElementById('reading-progress');
      if (bar) {
        const updateProgress = () => {
          const scrollTop = window.scrollY;
          const docHeight = document.documentElement.scrollHeight - window.innerHeight;
          bar.style.width = docHeight > 0 ? (scrollTop / docHeight * 100) + '%' : '0%';
        };
        window.addEventListener('scroll', updateProgress, { passive: true });
        updateProgress();
      }

      // Code copy buttons
      document.querySelectorAll('.prose pre').forEach(pre => {
        if (pre.querySelector('.copy-btn')) return;
        const btn = document.createElement('button');
        btn.className = 'copy-btn';
        btn.textContent = 'Copy';
        btn.addEventListener('click', async () => {
          const code = pre.querySelector('code')?.textContent || '';
          await navigator.clipboard.writeText(code);
          btn.textContent = 'Copied!';
          setTimeout(() => btn.textContent = 'Copy', 1500);
        });
        pre.appendChild(btn);
      });

      // TOC active heading highlight (Desktop)
      const tocLinks = document.querySelectorAll('.toc-link');
      if (tocLinks.length > 0) {
        const headingEls = Array.from(tocLinks).map(l =>
          document.getElementById(l.dataset.slug)
        ).filter(Boolean);
        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              tocLinks.forEach(l => l.classList.remove('text-foreground', 'font-medium'));
              const active = document.querySelector(`.toc-link[data-slug="${entry.target.id}"]`);
              if (active) active.classList.add('text-foreground', 'font-medium');
            }
          });
        }, { rootMargin: '-80px 0px -60% 0px' });
        headingEls.forEach(el => observer.observe(el));
      }
    }

    // Mobile TOC Logic
    function initMobileTOC() {
      const btn = document.getElementById('mobile-toc-btn');
      const overlay = document.getElementById('toc-overlay');
      const drawer = document.getElementById('toc-drawer');
      const closeBtn = document.getElementById('toc-close-btn');
      const mobileLinks = document.querySelectorAll('.mobile-toc-link');

      if (!btn || !overlay || !drawer) return;

      const openDrawer = () => {
        overlay.classList.remove('hidden');
        // Force reflow
        void overlay.offsetWidth;
        overlay.classList.remove('opacity-0');
        drawer.classList.remove('translate-y-full');
        document.body.style.overflow = 'hidden';
      };

      const closeDrawer = () => {
        drawer.classList.add('translate-y-full');
        overlay.classList.add('opacity-0');
        document.body.style.overflow = '';
        setTimeout(() => {
          overlay.classList.add('hidden');
        }, 300);
      };

      btn.addEventListener('click', openDrawer);
      overlay.addEventListener('click', closeDrawer);
      if (closeBtn) closeBtn.addEventListener('click', closeDrawer);

      mobileLinks.forEach(link => {
        link.addEventListener('click', (e) => {
          e.preventDefault();
          closeDrawer();

          const targetId = link.getAttribute('href').substring(1);
          const targetEl = document.getElementById(targetId);
          if (targetEl) {
            setTimeout(() => {
              targetEl.scrollIntoView({ behavior: 'smooth' });
              history.pushState(null, null, `#${targetId}`);
            }, 100);
          }
        });
      });
    }

    initBlogEnhancements();
    initMobileTOC();

    document.addEventListener('astro:after-swap', () => {
      initBlogEnhancements();
      initMobileTOC();
    });
  </script>
</BaseLayout>
