---
import BaseLayout from "@/components/layout/BaseLayout.astro"
import { getFriendList } from "@/db/queries"

const friends = await getFriendList()
---

<BaseLayout title="Friends | Tech Blog" description="Blogroll & friends">
  <div class="max-w-3xl mx-auto py-10">
    <h1 class="text-3xl font-bold tracking-tight mb-2 reveal">Friends</h1>
    <p class="text-muted-foreground mb-10 reveal">Cool people and interesting blogs.</p>

    <div class="grid gap-4 sm:grid-cols-2">
      {friends.map(friend => (
        <a
          href={friend.url}
          target="_blank"
          rel="noopener noreferrer"
          class="group flex items-center gap-4 rounded-lg border p-4 transition-all duration-300 ease-out hover:-translate-y-1 hover:shadow-lg hover:shadow-primary/5 hover:border-primary/20 reveal"
        >
          {friend.avatar ? (
            <img src={friend.avatar} alt={friend.name} class="h-12 w-12 rounded-full object-cover shrink-0 border" />
          ) : (
            <div class="h-12 w-12 rounded-full bg-muted flex items-center justify-center shrink-0 text-lg font-semibold text-muted-foreground">
              {friend.name.charAt(0).toUpperCase()}
            </div>
          )}
          <div class="min-w-0">
            <h3 class="font-semibold text-sm group-hover:text-primary transition-colors">{friend.name}</h3>
            {friend.description && (
              <p class="text-xs text-muted-foreground line-clamp-2 mt-0.5">{friend.description}</p>
            )}
          </div>
        </a>
      ))}
    </div>

    {friends.length === 0 && (
      <p class="text-muted-foreground text-center py-12">No friends added yet.</p>
    )}
  </div>
</BaseLayout>
