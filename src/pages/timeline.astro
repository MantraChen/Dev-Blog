---
import BaseLayout from "@/components/layout/BaseLayout.astro"
import { getTimelineList } from "@/db/queries"

const timelineItems = await getTimelineList()

const typeStyles: Record<string, string> = {
  career: "border-blue-500 bg-blue-500/10",
  education: "border-purple-500 bg-purple-500/10",
  milestone: "border-amber-500 bg-amber-500/10",
  learning: "border-green-500 bg-green-500/10",
}

const typeLabels: Record<string, string> = {
  career: "Career",
  education: "Education",
  milestone: "Milestone",
  learning: "Learning",
}
---

<BaseLayout title="Timeline | Tech Blog" description="Career and learning timeline">
  <div class="max-w-2xl mx-auto py-10">
    <h1 class="text-3xl font-bold tracking-tight mb-8 reveal">Timeline</h1>
    {timelineItems.length === 0 && (
      <p class="text-muted-foreground text-center py-12">No timeline entries yet.</p>
    )}
    <div class="relative border-l border-muted ml-3 space-y-8">
      {timelineItems.map((item) => (
        <div class="relative pl-8 reveal">
          <div class={`absolute -left-3 top-1.5 flex h-6 w-6 items-center justify-center rounded-full border text-xs font-bold ${typeStyles[item.type] || "border-muted bg-muted/10"}`}>
            {item.type.charAt(0).toUpperCase()}
          </div>
          <div class="flex flex-col gap-1">
            <div class="flex items-center gap-2">
              <time class="text-sm text-muted-foreground">{new Date(item.date).toLocaleDateString()}</time>
              <span class={`text-xs px-2 py-0.5 rounded-full border ${typeStyles[item.type] || ""}`}>
                {typeLabels[item.type] || item.type}
              </span>
            </div>
            <h3 class="text-lg font-semibold">
              {item.url ? (
                <a href={item.url} target="_blank" rel="noopener noreferrer" class="hover:underline">
                  {item.title}
                </a>
              ) : (
                item.title
              )}
            </h3>
            <p class="text-muted-foreground">{item.description}</p>
            {item.tags && item.tags.length > 0 && (
              <div class="flex flex-wrap gap-2 mt-2">
                {item.tags.map((tag) => (
                  <span class="text-xs border px-2 py-0.5 rounded-full bg-secondary/50">{tag}</span>
                ))}
              </div>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</BaseLayout>
